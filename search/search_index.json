{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":[" "],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Courses","text":"<p>\uc218\uc5c5\uc790\ub8cc\uc640 \uac15\uc758\uacc4\ud68d\uc11c\ub97c \uacf5\uac1c\ud558\ub294 \ud398\uc774\uc9c0\uc785\ub2c8\ub2e4.</p> <p>LAUS \uc5f0\uad6c\uc2e4 \ud648\uc73c\ub85c \ub3cc\uc544\uac00\uae30</p> <p>LAUS \uac15\uc758 \uc804\uccb4 \uac1c\uad04\ub85c \ub3cc\uc544\uac00\uae30</p> <ul> <li>\ub3c4\uc2dc\uc640 \uc8fc\uac70</li> </ul>"},{"location":"urbanism-housing/","title":"\uac15\uc758\uacc4\ud68d\uc11c","text":"<p>\uc5c5\ub370\uc774\ud2b8: 2026/07/22  (\ubcf8 \ubb38\uc11c\ub294 \ud559\uae30\uc911 \uacc4\uc18d \uc5c5\ub370\uc774\ud2b8 \uc608\uc815\uc774\ub2c8 \uc218\uac15\uc0dd\ub4e4\uc740 \ud655\uc778\ubc14\ub78d\ub2c8\ub2e4.)</p> <p>\ub3c4\uc2dc\uc640 \uc8fc\uac70 Urbanism and Housing M1498.003000 (001) 3 credits 2026\ud559\ub144\ub3c4 2\ud559\uae30</p> <p>\uc218\uc694\uc77c 14:00-16:50 | 39\ub3d9 508\ud638 \uac15\uc758\uc2e4 Room 508, Building 39</p> <p>ETL site: https://myetl.snu.ac.kr/courses/267903</p> <p>Instructor: \uac15\ubc94\uc900 Bumjoon Kang (39-501) bumjoon@snu.ac.kr | https://laus.snu.ac.kr/</p> <p>(2024\ub144\ubd80\ud130\ub294 \ud55c\uad6d\uc5b4\ub85c \uac15\uc758\ud569\ub2c8\ub2e4.)</p> <p>\ud83d\udce2 \ud559\uc0dd \uba74\ub2f4\uc740 \uc704 \uc6f9\uc0ac\uc774\ud2b8\uc5d0\uc11c \ubbf8\ub9ac \uc608\uc57d\uac00\ub2a5 (\ubcc4\ub3c4\uc758 \uc2dc\uac04\uc744 \uc6d0\ud55c\ub2e4\uba74 email \ubb38\uc758\ud560 \uac83) \uba74\ub2f4\uc694\uccad\uc744 \ud3ec\ud568\ud558\uc5ec \uc218\uc5c5\uad00\ub828 email \uc9c8\ubb38\uc2dc, \ubc18\ub4dc\uc2dc \uc81c\ubaa9\uc774 \u201c\ub3c4\uc2dc\uc640 \uc8fc\uac70\u201d \ubb38\uad6c\ub85c \uc2dc\uc791\ud574\uc57c\ud569\ub2c8\ub2e4 (\uc608: \u201c\ub3c4\uc2dc\uc640\uc0ac\ud68c \uc2dc\ud5d8 \uc77c\uc815 \uc9c8\ubb38\u201d). \uadf8\ub807\uc9c0 \uc54a\uc73c\uba74 \uc2a4\ud338\ucc98\ub9ac\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ud83d\udceb \ube44\uc988\ub2c8\uc2a4 \uc774\uba54\uc77c \uc4f0\ub294 \ubc95\uc744 \ucc38\uace0\ud558\uae30 \ubc14\ub78d\ub2c8\ub2e4.</p>"},{"location":"urbanism-housing/#course-objectives","title":"\uc218\uc5c5\ubaa9\ud45c Course Objectives","text":"<p>\ud83c\udfaf \ud575\uc2ec \uc9c8\ubb38: \uadf8\ub798\uc11c \uacb0\uad6d, \ud55c\uad6d \ub3c4\uc2dc (\ub300\ubd80\ubd84 \uc11c\uc6b8 \ubc0f \uc218\ub3c4\uad8c) \uc8fc\uac70\ud615\ud0dc, \ub3c4\uc2dc\ud615\ud0dc\ub294 \uc5b4\ub5bb\uac8c \ub9cc\ub4e4\uc5b4\uc84c\ub098?</p> <p>\uc704 \ubcf8 \uc218\uc5c5\uc5d0\uc11c\ub294 \uc704 \uc9c8\ubb38\uc5d0 \ub2f5\ud558\uae30 \uc704\ud574 \ub3c4\uc2dc\uc124\uacc4, \uacc4\ud68d, \uc81c\ub3c4 \uadf8\ub9ac\uace0 \ub3c4\uc2dc\ud615\ud0dc\ud559\uc758 \ubc29\ubc95\ub860\uc744 \uc774\ud574\ud558\ub294 \uac83\uc744 \ubaa9\ud45c\ub85c \ud55c\ub2e4. \uadf8\ub9ac\uace0 \uc2e0\ub3c4\uc2dc\uc640 \uc544\ud30c\ud2b8\ub97c \ud55c\uad6d \ub3c4\uc2dc, \uc8fc\uac70 \ud615\ud0dc\uc758 \ub300\ud45c\uc801 \ud2b9\uc9d5\uc774\ub77c\uace0 \uc124\uc815\ud558\uace0, \uc2e0\ub3c4\uc2dc\uc640 \uc544\ud30c\ud2b8\uc758 \ud615\uc131 \uacfc\uc815\uc744 \uc774\ud574\ud558\uace0 \ud568\uc758\ub97c \ud0d0\uad6c\ud55c\ub2e4. \ub9c8\uc9c0\ub9c9\uc73c\ub85c \ud604\uc7ac \uc6b0\ub9ac \ub3c4\uc2dc\uc640 \uc8fc\uac70\uc758 \uc774\uc288(\uc608: \ub3c4\uc2dc\uc8fc\uac70 \uc815\ube44\uc640 \uc7ac\uc0dd, \ucd95\uc18c\ub3c4\uc2dc\uc640 \uac74\ucd95)\ub97c \ub17c\uc758\ud55c\ub2e4.</p> <p>\uc774 \uc218\uc5c5\uc744 \ud1b5\ud574 \uc218\uac15\uc0dd\ub4e4\uc740 \uc0ac\ud68c\uc801 \ub9e5\ub77d \uc548\uc5d0\uc11c \ub3c4\uc2dc, \uc8fc\uac70 \ud615\ud0dc\ub97c \uc774\ud574\ud560 \uc218 \uc788\uac8c \ub420 \uac83\uc774\ub2e4. \ubcf8 \uac15\uc758\uc758 \uc218\uc5c5\ubc29\uc2dd\uc740 \uac15\uc758, \ubc1c\ud45c, \ud604\uc7a5\ub2f5\uc0ac, \ud559\uc0dd \ud504\ub85c\uc81d\ud2b8 \ub4f1\uc744 \ud3ec\ud568\ud560 \uc608\uc815\uc774\ub2e4. </p> <p>\ud83e\udde0 \ud575\uc2ec \uc8fc\uc81c </p> <ul> <li>\ub3c4\uc2dc\uc124\uacc4 \ubc0f \uacc4\ud68d \uc81c\ub3c4\uc640 \uac1c\ub150</li> <li>\ub3c4\uc2dc\ud615\ud0dc\ud559</li> <li>\uc544\ud30c\ud2b8\uc640 \uc2e0\ub3c4\uc2dc</li> <li>\ud604\ub300 \ud55c\uad6d \ub3c4\uc2dc \ubc0f \uc8fc\uac70 \uc774\uc288</li> </ul>"},{"location":"urbanism-housing/#evaluation","title":"\ud3c9\uac00\ubc29\ubc95 Evaluation","text":"<p>\uc11c\uc6b8\ub300\ud559\uad50 \ud559\uc5c5\uc131\uc801 \ucc98\ub9ac \uaddc\uc815 \uc81c3\uc870\ub97c \ub530\ub77c \uc131\uc801\uc744 \ubd80\uc5ec\ud558\ub418, \ud559\uc0dd\ub4e4\uc758 \uc808\ub300\uc801 \uc131\ucde8\ub3c4\uc5d0 \ub530\ub77c \uc808\ub300\ud3c9\uac00\uc2dd \ub4f1\uae09\ubcc4 \ube44\uc728 \uc870\uc815\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. </p> <p>\uae30\ubcf8\uc801\uc778 \ud3c9\uac00 \ubc30\ubd84:</p> <ul> <li>\ucd9c\uc11d \ubc0f \uc218\uc5c5 \ucc38\uc5ec 15%</li> <li>\uacfc\uc81c\ubb3c 25%</li> <li>\uc911\uac04\uace0\uc0ac 25% + \uae30\ub9d0\uace0\uc0ac 25%</li> <li>\uae30\ud0c0 10%</li> </ul> <p>\ud83d\udce2 \ucd9c\uc11d\uc740 \uc911\uc694\ud569\ub2c8\ub2e4. \ucd9c\uc11d\uc740 \uc218\uc5c5 \uc2dc\uac04 \uc911 \uc218\uc5c5\uc5d0 \uc801\uadf9 \ucc38\uc5ec\ud558\ub294 \uac83\uc744 \uc758\ubbf8\ud569\ub2c8\ub2e4. \ubd88\uc131\uc2e4\ud55c \ucc38\uc11d\uc740 \ucd9c\uc11d\uc73c\ub85c \uc778\uc815\ub418\uc9c0 \uc54a\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.  \ubd88\uac00\ud53c\ud55c \uacb0\uc11d\uc2dc \uc11c\uc6b8\ub300\ud559\uad50 \ud559\uc5c5\uc131\uc801 \ucc98\ub9ac \uaddc\uc815 \uc81c4\uc870\uc5d0 \ub530\ub77c, \ud574\ub2f9 \ud559\uc0dd\uc774 \uc99d\ube59\uc790\ub8cc\ub97c \uc774\uba54\uc77c \ud639\uc740 \uc9c1\uc811 \uc81c\ucd9c\ud560 \uacbd\uc6b0 \ucd9c\uc11d\uc73c\ub85c \uc778\uc815\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. </p>"},{"location":"urbanism-housing/#textbooks-and-course-materials","title":"\uad50\uc7ac \ubc0f \ucc38\uace0\ubb38\ud5cc Textbooks and Course Materials","text":"<p>\ud55c\uad6d\ub3c4\uc2dc\uc124\uacc4\ud559\ud68c (2014). \u201c\ub3c4\uc2dc\uc124\uacc4\uc758 \uc774\ud574\u201d. \uc11c\uc6b8: \ubcf4\uc131\uac01 (\uc5b4\ub290 \uc5f0\ub3c4 \ud310\uc774\uac74 \uc0c1\uad00\uc5c6\uc74c) [\uc11c\uc6b8\uc2dc\uc815\uac1c\ubc1c\uc5f0\uad6c\uc6d0 (2001). \uc11c\uc6b8 20\uc138\uae30 \uacf5\uac04\ubcc0\ucc9c\uc0ac, \uc11c\uc6b8\uc2dc\uc815\uac1c\ubc1c\uc5f0\uad6c\uc6d0 \ud3b8](https://snu-primo.hosted.exlibrisgroup.com/permalink/f/1l6eo7m/82SNU_INST21478131910002591 * \ub2e4\uc6b4\ub85c\ub4dc \ub9c1\ud06c</p>"},{"location":"urbanism-housing/#recommended-readings","title":"\ucd94\uac00 \uad8c\uc7a5 \uc77d\uc744\uac70\ub9ac Recommended Readings","text":"<p>\uc815\ub9ac\uc911</p>"},{"location":"urbanism-housing/#importance-notices","title":"\uc720\uc758\uc0ac\ud56d Importance Notices","text":"<ul> <li>\uc7a5\uc560\ud559\uc0dd\uc9c0\uc6d0\uc13c\ud130\uc758 \uc8fc\uc694 \uc9c0\uc6d0 \uc0ac\ud56d\uc744 \ucc38\uace0:<ul> <li>https://www.snu.ac.kr/campuslife/aid/disabled</li> <li>\uae30\ud0c0 \ub3c4\uc6c0\uc774 \ud544\uc694\ud558\ub2e4\uba74 \ub2f4\ub2f9 \uad50\uc218\uc640 \uc0c1\uc758 \ubc14\ub78d\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\uc11c\uc6b8\ub300\ud559\uad50 \ud559\uce59(\uc81c5\uc808 \uc2dc\ud5d8\uacfc \uc131\uc801)\uc744 \ubc18\ub4dc\uc2dc \uc219\uc9c0\ud558\uae30 \ubc14\ub78d\ub2c8\ub2e4.</p> <ul> <li>\ud83e\udd16 \uc218\uc5c5\uc77c\uc218 2/3 \uc774\uc0c1 \ucd9c\uc11d\ud558\uc5ec\uc57c \uc131\uc801\ucde8\ub4dd \uac00\ub2a5 (\uadf8\ub807\uc9c0 \uc54a\ub2e4\uba74 F)</li> </ul> </li> <li> <p>\ud83d\udca2 \uc2dc\ud5d8 \ubd80\uc815\ud589\uc704, \uacfc\uc81c\ubb3c \ud45c\uc808 \ubc0f \uae30\ud0c0 \ubd80\uc815\ud55c \ubc29\ubc95\uc73c\ub85c \uad50\uacfc\ubaa9\uc758 \uc131\uc801\uc744 \ucde8\ub4dd\ud558\ub824 \ud560 \uacbd\uc6b0, \ubd80\uc815\ud589\uc704 \uc0ac\uc2e4\uc744 \ud559\uacfc\uc5d0 \ubcf4\uace0\ud558\uace0 \ubcf8 \uad50\uacfc\ubaa9 \uc131\uc801\uc740 F \ucc98\ub9ac\ud569\ub2c8\ub2e4.</p> </li> <li>\ud83d\ude00 \uc7a5\uc560\ud559\uc0dd\uc740 \ud559\uae30 \uccab \uc8fc\uc5d0 \uad50\uacfc\ubaa9 \ub2f4\ub2f9\uad50\uc218\uc640\uc758 \uba74\ub2f4\uc744 \ud1b5\ud574 \ucd9c\uc11d, \uac15\uc758, \uacfc\uc81c \ubc0f \uc2dc\ud5d8\uc5d0 \uad00\ud55c \uad50\uc218\ud559\uc2b5 \uc9c0\uc6d0\uc0ac\ud56d\uc744 \uc694\uccad \ubc14\ub78d\ub2c8\ub2e4. \ub2f4\ub2f9\uad50\uc218 \ub610\ub294 \uc7a5\uc560\ud559\uc0dd\uc9c0\uc6d0\uc13c\ud130\ub97c \ud1b5\ud574 \ud544\uc694\ud55c \uc9c0\uc6d0\ubc1b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4 https://snudanbi.snu.ac.kr/</li> <li>\ud83d\udcf5 \ub2f4\ub2f9\uad50\uc218\uac00 \ud310\ub2e8\ud558\ub294 \uc218\uc5c5\ubc29\ud574\ud589\uc704\uc5d0\ub294 \ubc8c\uc810 \ubd80\uc5ec\ud569\ub2c8\ub2e4 (\uac74\ubcc4 \ucd1d \ud3c9\uac00\uc810\uc218\uc5d0\uc11c ~5% \ud3ec\uc778\ud2b8\uc529 \uac10\uc810. \uc608: \uc218\uc5c5\uc2dc\uac04 \uc911 \uac8c\uc784 5% \uac10\uc810).</li> <li>\uc218\uac15\uc0dd\ub4e4\uc740 AI\ub97c \ud65c\uc6a9\ud558\uc5ec \ud559\uc2b5\ud558\uace0, \uacfc\uc81c\ubb3c\uc744 \uc81c\ucd9c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub2e8, \uc11c\uc6b8\ub300\ud559\uad50 AI \uac00\uc774\ub4dc\ub77c\uc778\uc5d0 \ub530\ub77c \ud22c\uba85\ud55c \ud65c\uc6a9 \uacf5\uac1c \ubc0f \uba85\uc2dc \uc6d0\uce59\uc744 \ub530\ub77c\uc57c \ud569\ub2c8\ub2e4 (\uc989, \ubcf4\uace0\uc11c\uc5d0 AI \ub3c4\uad6c\ub85c \uc0dd\uc131\ud55c \ubb38\uc7a5 \ubc0f \uc790\ub8cc \ub4f1\uc744 \uc0ac\uc6a9\ud560 \uacbd\uc6b0, \uac01\uc8fc \ub610\ub294 \ucc38\uace0\ubb38\ud5cc \ud30c\ud2b8\uc5d0 AI \ub3c4\uad6c \ud65c\uc6a9 \ub0b4\uc5ed \uba85\uc2dc)</li> <li>\uc11c\uc6b8\ub300\ud559\uad50 AI \uac00\uc774\ub4dc\ub77c\uc778\uc744 \ubc18\ub4dc\uc2dc \uc219\uc9c0\ud558\uae30 \ubc14\ub78d\ub2c8\ub2e4.</li> <li> <p>\ucc38\uace0: \ud55c\uad6d\uc5f0\uad6c\uc7ac\ub2e8\uc774 \uc548\ub0b4\ud558\ub294 AI \uc0ac\uc6a9 \uc5ec\ubd80 \uba85\uc2dc \ubc29\ubc95</p> <p>OpenAI. (2025). ChatGPT (5.0, 2025.08.08), \ub300\ud615\uc5b8\uc5b4\ubaa8\ub378(LLM), https://chatgpt.com/ \"\uc5f0\uad6c\uac1c\ubc1c\uacfc\uc81c\uc758 \ucd94\uc9c4\uc804\ub7b5, \ubc29\ubc95 \ubc0f \ucd94\uc9c4\uccb4\uacc4\" \uc791\uc131\uc2dc \uc5f0\uad6c\ubc29\ubc95 \ub3c4\uc2dd\ud654\ub97c \uc704\ud574 AI \ub3c4\uad6c\ub97c \ud65c\uc6a9\ud558\uc600\uc74c. p. 24\uc758 \uadf8\ub9bc \ubc0f \ud45c\ub294 \ubaa8\ub450 AI \ub3c4\uad6c\ub85c \uc0dd\uc131\ub418\uc5c8\uc73c\uba70, \uc5f0\uad6c\uc790\uc758 \uac80\ud1a0\ub97c \ud1b5\ud574 \uc77c\ubd80 \uc218\uc815\ud558\uc5ec \ubcf8 \ubcf4\uace0\uc11c\uc5d0 \uc218\ub85d\ud568.</p> </li> <li> <p>\ud83c\udf88 BE PROFESSIONAL!!!</p> </li> </ul>"},{"location":"urbanism-housing/#_1","title":"\uc8fc\ucc28\ubcc4 \uacc4\ud68d","text":"<p>\uc8fc\ucc28\ubcc4 \uc138\ubd80\uacc4\ud68d</p>"},{"location":"urbanism-housing/#assignmensts-tbd","title":"\uacfc\uc81c\ubb3c Assignmensts (TBD)","text":""},{"location":"urbanism-housing/schedule/","title":"\uc8fc\ucc28\ubcc4\uacc4\ud68d","text":""},{"location":"urbanism-housing/schedule/#1-introduction","title":"1 \uc8fc\ucc28: Introduction","text":"<p>2026-09-02 \ub3c4\uc2dc\uc640 \uc8fc\uac70\ub97c \ubcf4\ub294 \uad00\uc810 - \uac15\uc758 \uc18c\uac1c\uc640 \uc6b4\uc601 \ubc29\uc2dd - \uac74\ucd95\uc758 \ub9e5\ub77d, \ub3c4\uc2dc\uc640 \uc8fc\uac70 (\uc9c4\uacf5/\ubb34\ub9e5\ub77d \uac74\ucd95\uc740 \uc5c6\uc74c) - \ub3c4\uc2dc\ud654\uc758 \uc555\ub825\uacfc \uc11c\uc6b8\uc758 \ud2b9\uc218\uc131 - \uc0ac\ub840: \uc778\uc0ac\ub3d9 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d\uacfc \uc308\uc9c0\uae38 - \ub3c4\uc2dc\uc640 \uc8fc\uac70, \uc774\uc81c \ub2e4\uc2dc \ud574\uacb0\ud574\uc57c\ud560 \ubb38\uc81c\ub85c \ub4f1\uc7a5 - Master plan, land use plan, design guideline\uc758 \ucc28\uc774 - Urban design\uc758 \uc815\uc758: \uc2dc\uac01\uc608\uc220, \uc0ac\ud68c\uc801 \ud65c\uc6a9\uc131, \uc7a5\uc18c\ub9cc\ub4e4\uae30 - \ud559\uc0dd \uac01\uc790\uc758 \ub3c4\uc2dc\uc640 \uc8fc\uac70 \ubb38\uc81c \uc815\uc758 - \uae30\uc874 PDF: UH_01 \uc804\uccb4 \u2014 s.1-15(\ub3c4\uc2dc \uc131\uc7a5\u00b7\uc9d1\uc801\u00b7\uc7ac\uc0b0\uad8c\u00b7\uac74\uc124\ubc95 \uccb4\uacc4), s.15-31(UD \uac1c\ub150\uc0ac\uc640 \uc138 \ud328\ub7ec\ub2e4\uc784); UH_02 s.2-7(\uc791\uc740/\ud070 \uc815\uc758\u00b7\uc7a5\uc18c\ub9cc\ub4e4\uae30); UH_02 s.8-16(\uc778\uc0ac\ub3d9 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d\u00b7\uc308\uc9c0\uae38\u00b7\ub3c4\uc2dc\uc124\uacc4\uac00 \uc5ed\ud560\u00b7\ud604\ub300 \uc774\uc288)</p>"},{"location":"urbanism-housing/schedule/#2-1","title":"2 \uc8fc\ucc28: \uc11c\uc6b81","text":"<p>2026-09-09 1945-1992\ub144, \uc778\uad6c\ud3ed\uc99d\uae30\uc758 \uc11c\uc6b8 - 1945\ub144 \uc774\ud6c4 \uc11c\uc6b8 \uc778\uad6c \uc99d\uac00\uc640 \uc218\ub3c4\uad8c \uacf5\uac04\uad6c\uc870 - 1960-1970\ub144\ub300 \ud1a0\uc9c0\uad6c\ud68d\uc815\ub9ac\uc0ac\uc5c5\uacfc \ub3c4\uc2dc\ud615\ud0dc - \uc8fc\ud0dd\uad00\ub828 \ubc95\uc81c\uc640 \ub2e4\uac00\uad6c, \ub2e4\uc138\ub300 \uc81c\ub3c4\uc758 \ub4f1\uc7a5\uacfc \uc8fc\ud0dd\ud615\ud0dc (9\uc8fc\ucc28 \uc8fc\uc81c) - \uc5ec\uc758\ub3c4, \uc7a0\uc2e4, \ubaa9\ub3d9, \uc0c1\uacc4, \uc0ac\ub2f9\uc758 \uacc4\ud68d \ub17c\ub9ac - \ubd88\ub7c9\uc8fc\uac70\uc9c0 \uc815\ube44\uc640 \ubbfc\uac04\ud569\ub3d9\uc7ac\uac1c\ubc1c\uc758 \ucd9c\ud604 - \uae30\uc874 PDF: UH_03(\uc2e0\u00b757\ub9e4) s.1-15(\uc77c\uc81c \uc2dc\uad6c\uac1c\uc815\u00b7\uc870\uc120\uc2dc\uac00\uc9c0\uacc4\ud68d\ub839\u00b7\ud574\ubc29\ud6c4 \uc11c\uc6b8 \uacf5\uac04\uad6c\uc870\u00b71960-70s \ubc95\uc81c\u00b7\ud1a0\uc9c0\uad6c\ud68d\uc815\ub9ac\u00b7\ud658\uc9c0/\uac10\ubcf4/\uccb4\ube44\uc9c0\u00b7\ud654\uace1), s.27-28(\ud0dd\uc9c0\uac1c\ubc1c\ucd09\uc9c4\ubc95\u00b7\ubaa9\ub3d9), s.32(\uc5ec\uc758\ub3c4), s.36-38(\ubc18\ud3ec\u00b7\uc7a0\uc2e4\u00b7\uacfc\ucc9c), s.41-50(\ubaa9\ub3d9 \uc704\uacc4\u00b7\uc0c1\uacc4 \uac1c\ubc29\uac00\uad6c\u00b7\uc0ac\ub2f94\uad6c\uc5ed \ud569\ub3d9\uc7ac\uac1c\ubc1c\u00b7\uc784\ub300\uc544\ud30c\ud2b8) - \ucc38\uace0: \ub2e4\uac00\uad6c\u00b7\ub2e4\uc138\ub300 \uc81c\ub3c4(s.16-26)\ub294 9\uc8fc\ucc28\uc5d0\uc11c \ubcf8\uaca9\uc801\uc73c\ub85c \ub2e4\ub8f8</p>"},{"location":"urbanism-housing/schedule/#3-2","title":"3 \uc8fc\ucc28: \uc11c\uc6b82","text":"<p>2026-09-16 1992\ub144 \uc774\ud6c4, \uc11c\uc6b8\uc758 \uc804\ud658\uacfc \ud655\uc7a5</p> <ul> <li>1992\ub144 \uc774\ud6c4 \uc11c\uc6b8\uc758 \uc131\uc7a5 \ub454\ud654\uc640 \ub3c4\uc2ec \uc7ac\ud3b8</li> <li>\uacc4\ud68d\ub41c 1\uae30 \uc2e0\ub3c4\uc2dc (6\uc8fc\ucc28 \uc8fc\uc81c)</li> <li>\uc8fc\ud0dd\uc7ac\uac1c\ubc1c\uacfc \ub274\ud0c0\uc6b4\uc758 \ub3c4\uc2dc\ud615\ud0dc\uc801 \ud6a8\uacfc</li> <li>\uccad\uacc4\ucc9c\ubcf5\uc6d0\uacfc \uacf5\uacf5\uc601\uc5ed \uc911\uc2ec \ub3c4\uc2dc\uc124\uacc4</li> <li>\uc778\uc0ac\ub3d9 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d, \uc7a5\uc18c\ub9cc\ub4e4\uae30, \ubcf4\uc874\uacfc \uac1c\ubc1c\uc758 \uae34\uc7a5</li> <li>2040 \uc11c\uc6b8\ud50c\ub79c\uacfc \ub2e4\ud575, \ubcf4\ud589, \uc218\ubcc0, \uc8fc\uac70\uc815\ucc45</li> <li>\uae30\uc874 PDF: UH_03(\uc2e0) s.7(2040 \ub3c4\uc2dc\uae30\ubcf8\uacc4\ud68d\u00b790\ub144\ub300 \uc774\ud6c4 \uc11c\uc6b8), s.50-57(1\uae30 \uc2e0\ub3c4\uc2dc\u00b7\ubd84\ub2f9\u00b7\ud310\uad50\u00b7\uc138\uc885\u00b7\uc81c\ub3c4\uc801 \ub3c4\uc2dc\ud615\ud0dc \uc0dd\uc0b0 \uc885\ud569); UH_02 s.8-16(\uc778\uc0ac\ub3d9 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d\u00b7\uc308\uc9c0\uae38\u00b7\ub3c4\uc2dc\uc124\uacc4\uac00 \uc5ed\ud560\u00b7\ud604\ub300 \uc774\uc288); UH_06 s.10-11(1991 \uc0c1\uc138\uacc4\ud68d\u21922000 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d)</li> <li>\u203b \ubcf4\uac15 \ud544\uc694: \uccad\uacc4\ucc9c \ubcf5\uc6d0, \ub274\ud0c0\uc6b4(2002~) \u2014 \ub450 PDF \uc5b4\ub514\uc5d0\ub3c4 \uc5c6\uc74c. \uc8fc\ud0dd\uc7ac\uac1c\ubc1c\u00b7\ub3c4\uc2dc\uc7ac\uc0dd \uc2ec\ud654 \uc790\ub8cc \ubcc4\ub3c4 \ud655\ubcf4 \ud544\uc694</li> </ul>"},{"location":"urbanism-housing/schedule/#4","title":"4 \uc8fc\ucc28: \ub2f5\uc0ac","text":"<p>2026-09-23 \uc11c\uc6b8\uc5ed\uc0ac\ubc15\ubb3c\uad00 \ubc0f \ub3c4\uc2ec\ubd80</p> <ul> <li>\uc11c\uc6b8\uc5ed\uc0ac\ubc15\ubb3c\uad00 \uc804\uc2dc\uc5d0\uc11c \ubcf4\ub294 \uc11c\uc6b8\uc758 \uacf5\uac04\uad6c\uc870\uc758 \ud615\uc131</li> <li>\uc608\uc815: \uc804\uc2dc\ud68c (\uc11c\uc6b8\ub3c4\uc2dc\uae30\ubcf8\uacc4\ud68d '66, 1966\ub144 \uc11c\uc6b8\uc758 \ubbf8\ub798\uac00 \ub9cc\ub4e4\uc5b4\uc84c\ub2e4.)[https://museum.seoul.go.kr/www/board/NR_boardView.do?bbsCd=1015&amp;seq=20260107093621162&amp;sso=ok]</li> <li>\ub3c4\uc2ec\uc7ac\uac1c\ubc1c \uad6c\uc5ed \uad00\ucc30</li> <li>\uacf5\uacf5\uc601\uc5ed\uacfc \uac74\ubb3c \uc800\uce35\ubd80\uc758 \uad00\uacc4</li> <li>\uae30\uc874 PDF: UH_03(\uc2e0) s.2-5(\uc870\uc120 \ud55c\uc131\u00b7\uc77c\uc81c \uacbd\uc131\u00b7\ud574\ubc29\ud6c4 \uc11c\uc6b8 \uacf5\uac04\uad6c\uc870), UH_02 s.8-11(\uc778\uc0ac\ub3d9 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d\u00b7\uc308\uc9c0\uae38)</li> <li>\u203b \uc804\uc6a9 \uc2ac\ub77c\uc774\ub4dc \uc5c6\uc74c \u2014 \ub2f5\uc0ac \ub3d9\uc120 \uc548\ub0b4\u00b7\uae30\ub85d \uc591\uc2dd\uc740 \uc2e0\uaddc \uc791\uc131</li> </ul>"},{"location":"urbanism-housing/schedule/#5","title":"5 \uc8fc\ucc28: \ub3c4\uc2dc\ud615\ud0dc\ub860","text":"<p>2026-09-30 \ub3c4\uc2dc\ud615\ud0dc\ub97c \uc77d\ub294 \uac1c\ub150\uacfc \ubc29\ubc95 - Urban form\uacfc urban morphology - Town plan: street, plot, building, land use - \ud544\uc9c0\uc8fc\uae30, fringe belt, plan-unit - Muratori\uc640 Caniggia\uc758 \uc720\ud615\ud559\uc801 \uacfc\uc815 - \ud615\ud0dc-\ud589\ud0dc \uc5f0\uad6c, \uc5ed\uc0ac\uc5f0\uad6c, \uc5d0\ub108\uc9c0\uc640 \ubc00\ub3c4 \ub17c\uc758 - \uae30\uc874 PDF: UH_04 \uc804\uccb4 \u2014 s.2-7(\ub3c4\uc2dc\uc870\uc9c1\u00b7urban tissue\u00b7\uac00\ub85c+\ud544\uc9c0+\uac74\ucd95\ubb3c), s.8-12(Conzen town-plan analysis\u00b7plan-unit\u00b7\ud544\uc9c0\uc8fc\uae30\u00b7\uc9c4\uc601\ud6a8\u00b7\uc548\uac74\ud601 \ud55c\uad6d \uc801\uc6a9), s.13-20(Muratori\u00b7Caniggia \uc720\ud615\ud559\uc801 \uacfc\uc815\u00b7Aldo Rossi), s.21-29(\ud615\ud0dc-\ud589\ud0dc\u00b7\uc5d0\ub108\uc9c0/\ubc00\ub3c4\u00b7\ub3c4\uc2ec\ubd80 \uc18c\ub2e8\uc704 \uc815\ube44)</p>"},{"location":"urbanism-housing/schedule/#6","title":"6 \uc8fc\ucc28: \uc2e0\ub3c4\uc2dc","text":"<p>2026-10-07 \ud0dd\uc9c0\uac1c\ubc1c, \uacf5\uacf5\uc8fc\ud0dd, 1\uae30-3\uae30 \uc2e0\ub3c4\uc2dc - \ud0dd\uc9c0\uac1c\ubc1c\ucd09\uc9c4\ubc95\uacfc \uacf5\uacf5\uc8fc\ud0dd \uacf5\uae09 \uccb4\uacc4 - \uc7a0\uc2e4, \ubaa9\ub3d9, \ubd84\ub2f9, \ud310\uad50\uc758 \uacc4\ud68d \uc6d0\ub9ac - \uadfc\ub9b0\uc8fc\uad6c, microdistrict, \ub2e8\uc704\uacc4\ud68d - 1\uae30, 2\uae30, 3\uae30 \uc2e0\ub3c4\uc2dc \ube44\uad50 - \ub3c4\uc2dc\uac74\ucd95\ud1b5\ud569\uacc4\ud68d\uacfc \ucd5c\uadfc \uacf5\uacf5\uc8fc\ud0dd \uc124\uacc4 \uc7c1\uc810   - \ube14\ub85d\ud06c\uae30, \uac00\ub85c\uad00\uacc4   - \ud1b5\ud569\uacc4\ud68d - N\ubd84 \ub3c4\uc2dc - \uae30\uc874 PDF: UH_03(\uc2e0) s.33-35(Kenzo Tange\u00b7Clarence Perry \uadfc\ub9b0\uc8fc\uad6c\u00b7Microdistrict), s.36-38(\ubc18\ud3ec\u00b7\uc7a0\uc2e4 \ubaa8\ub4c8\u00b7\uacfc\ucc9c\u00b7\ub300\ub355), s.27-28\u00b742-44(\ud0dd\uc9c0\uac1c\ubc1c\u00b7\ubaa9\ub3d9 \uc704\uacc4), s.45(\uc0c1\uacc4), s.50-51(1\uae30 \uc2e0\ub3c4\uc2dc \ube44\uad50\ud45c\u00b7\ubd84\ub2f9 \uc8fc\uad6c\uc911\uc2ec), s.54-55(\ud310\uad50\u00b7\uc138\uc885) - \u203b \ubcf4\uac15 \ud544\uc694: 2\uae30\u00b73\uae30 \uc2e0\ub3c4\uc2dc \ube44\uad50, \ub3c4\uc2dc\uac74\ucd95\ud1b5\ud569\uacc4\ud68d, \ucd5c\uadfc \uacf5\uacf5\uc8fc\ud0dd \uc124\uacc4 \uc7c1\uc810 \u2014 PDF\uc5d0 \uc5c6\uc74c(\uc2e0\uaddc)</p>"},{"location":"urbanism-housing/schedule/#7","title":"7 \uc8fc\ucc28: \ub3c4\uc2dc\uc124\uacc4\uc758 \ub3c4\uad6c\ub4e4","text":"<p>2026-10-14 \uc6a9\ub3c4\uc9c0\uc5ed\uc81c, \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d, \uc815\ube44\uacc4\ud68d, \ub3c4\uc2dc\uac74\ucd95\ud1b5\ud569 - \ub3c4\uc2dc\uad00\ub828 \ubc95\uacfc \ud589\uc815\uacc4\ud68d\uc758 \ubc95\uc801 \uc9c0\uc704 - \uad6d\ud1a0\uacf5\uac04\uacc4\ud68d \uccb4\uacc4\uc640 \uacc4\ud68d \uc704\uacc4 - \uc6a9\ub3c4\uc9c0\uc5ed\uc81c\uc640 \uac74\ucd95\uc81c\ud55c - \ub3c4\uc2dc\uc124\uacc4, \uc0c1\uc138\uacc4\ud68d, \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d\uc758 \uc5ed\uc0ac - \uc815\ube44\uacc4\ud68d, \uac74\ucd95\ud611\uc815\uc81c, \ub3c4\uc2dc\uac74\ucd95\ud1b5\ud569\uacc4\ud68d - \uae30\uc874 PDF: UH_06 \uc804\uccb4 \u2014 s.1-2(\ubc95\ub960\uc720\ubcf4\u00b7\uacc4\ud68d\uace0\uad8c\u00b7\ud589\uc815\uacc4\ud68d\u00b7\uc774\uc775\ud615\ub7c9), s.5-6(\uad6d\ud1a0\uacf5\uac04\uacc4\ud68d \uccb4\uacc4\u00b7\ud604\ud589 \ubc95\uccb4\uacc4), s.7-9(\uc6a9\ub3c4\uc9c0\uc5ed\uc81c\u00b7\uad6d\uacc4\ubc95 36\u00b771\u00b776\uc870\u00b7\uac74\ucd95\uc81c\ud55c), s.10-11(1980 \ub3c4\uc2dc\uc124\uacc4\u21921991 \uc0c1\uc138\uacc4\ud68d\u21922000 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d), s.12-17(\uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d \uad6c\uc131\u00b7\uc0ac\ub840\u00b7\uc2e4\ud6a8\uc131), s.3-4(\ud30c\uc8fc\ucd9c\ud310\ub2e8\uc9c0\u00b7\uac74\ucd95\ud611\uc815\uc81c); UH_03(\uc2e0) s.39-40(1980 \ub3c4\uc2dc\uc124\uacc4\uc81c\ub3c4\u00b7TDR\u00b7\uc728\uace1\ub85c/\ud14c\ud5e4\ub780\ub85c \uac04\uc120\ub3c4\ub85c\ubcc0 \ub3c4\uc2dc\uc124\uacc4); UH_02 s.8-13(\uc778\uc0ac\ub3d9 \uc9c0\uad6c\ub2e8\uc704\uacc4\ud68d) - \u203b \ubcf4\uac15 \ud544\uc694: \ub3c4\uc2dc\uac74\ucd95\ud1b5\ud569\uacc4\ud68d\uc740 \ucd5c\uc2e0 \uc81c\ub3c4(PDF\uc5d0 \uc5c6\uc74c)</p>"},{"location":"urbanism-housing/schedule/#8","title":"8 \uc8fc\ucc28: \uc911\uac04\uace0\uc0ac","text":"<p>2026-10-21</p>"},{"location":"urbanism-housing/schedule/#9","title":"9 \uc8fc\ucc28: \u975e\uc544\ud30c\ud2b8","text":"<p>2026-10-28 \ub2e4\uac00\uad6c, \ub2e4\uc138\ub300, \ub3c4\uc2dc\ud615\uc0dd\ud65c\uc8fc\ud0dd, \ucf54\ub9ac\ube59</p> <ul> <li>\ub2e4\uac00\uad6c\uc640 \ub2e4\uc138\ub300\uc758 \ubc95\uc81c\ud654</li> <li>\uc77c\ubc18\uc8fc\uac70\uc9c0\uc5ed \ud544\uc9c0\uc640 \uc8fc\ucc28\uc7a5\ubc95</li> <li>\ub3c4\uc2dc\ud615\uc0dd\ud65c\uc8fc\ud0dd, \uc624\ud53c\uc2a4\ud154, \uc0dd\ud65c\uc219\ubc15\uc2dc\uc124, \ucf54\ub9ac\ube59</li> <li>\ube44\uc544\ud30c\ud2b8 \uc7a5\uc810: \uc811\uadfc\uc131, \uc810\uc9c4\uc131, \ub2e4\uc591\uc131</li> <li>\ube44\uc544\ud30c\ud2b8 \ud55c\uacc4: \uc548\uc804, \uad00\ub9ac, \ucc44\uad11, \uc8fc\ucc28, \uad8c\ub9ac\uad00\uacc4</li> <li>\uae30\uc874 PDF: UH_03(\uc2e0) s.16-26(\ub2e4\uc138\ub300\u00b7\ub2e4\uac00\uad6c \uc81c\ub3c4 \uc5f0\ud45c\u00b7\uc6a9\ub3c4\uc9c0\uc5ed \uc885\uc138\ubd84\ud654\u00b7\ub3c4\uc2dc\ud615\uc0dd\ud65c\uc8fc\ud0dd 2009\u00b7\ub300\uce58\ub3d9 \ud544\uc9c0 \uc0ac\ub840\u00b7\uc8fc\ucc28\uc7a5\ubc95 \ubcc0\ucc9c\u00b7\uac74\ucd95\ubb3c\ub300\uc7a5 \ud45c\uc81c\ubd80/\uc804\uc720\ubd80 \ud310\ub3c5)</li> </ul>"},{"location":"urbanism-housing/schedule/#10","title":"10 \uc8fc\ucc28: \uc544\ud30c\ud2b8","text":"<p>2026-11-04 \ub2e8\uc9c0\uacc4\ud68d\uacfc \ud3c9\uba74\uc758 \ubcc0\ud654 - \uc544\ud30c\ud2b8 \ub2e8\uc9c0\uc758 \ub4f1\uc7a5\uacfc \ub300\ub7c9\uacf5\uae09 - \uadfc\ub9b0\uc8fc\uad6c, \uc288\ud37c\ube14\ub85d, \uc8fc\ub3d9 \ubc30\uce58, \uc624\ud508\uc2a4\ud398\uc774\uc2a4 - \uc784\ub300\uc544\ud30c\ud2b8\uc640 \ubd84\uc591\uc544\ud30c\ud2b8\uc758 \uacf5\uac04\uc801 \ucc28\uc774 - \ud3c9\uba74\uc758 \ud45c\uc900\ud654: \ubc29, \uac70\uc2e4, \ubc1c\ucf54\ub2c8, \uc11c\ube44\uc2a4\uba74\uc801 - \ube0c\ub79c\ub4dc\ud654, \ucee4\ubba4\ub2c8\ud2f0 \uc2dc\uc124, \ub2e8\uc9c0 \ub0b4\ubd80\ud654 - \uae30\uc874 PDF: UH_03(\uc2e0) s.36-37(\ubc18\ud3ec\uc544\ud30c\ud2b8\u00b7\uc7a0\uc2e4 \uc288\ud37c\ube14\ub85d/\ubaa8\ub4c8 \ubc18\ubcf5), s.50-53(\uc784\ub300\uc544\ud30c\ud2b8\u00b7\ubd84\ub2f9 \uc8fc\uad6c\uc911\uc2ec\uc2dc\uc124\u00b7Apartment Urbanism) - \u203b \ubcf4\uac15 \ud544\uc694: \ud3c9\uba74 \ud45c\uc900\ud654(\ubc29/\uac70\uc2e4/\ubc1c\ucf54\ub2c8/\uc11c\ube44\uc2a4\uba74\uc801)\u00b7\ube0c\ub79c\ub4dc \uc544\ud30c\ud2b8\u00b7\ucee4\ubba4\ub2c8\ud2f0 \uc2dc\uc124 \u2014 PDF\uc5d0 \uc595\uac70\ub098 \uc5c6\uc74c</p>"},{"location":"urbanism-housing/schedule/#11","title":"11 \uc8fc\ucc28: \ub178\ud6c4 \uacf5\ub3d9\uc8fc\ud0dd","text":"<p>2026-11-11 \ub178\ud6c4 \uacf5\ub3d9\uc8fc\ud0dd\uacfc \uc815\ube44</p> <ul> <li>\ub178\ud6c4 \uacf5\ub3d9\uc8fc\ud0dd\uc758 \uaddc\ubaa8\uc640 \uc2dc\uae30</li> <li>\uc548\uc804\uc9c4\ub2e8, \uc7ac\uac74\ucd95, \ub9ac\ubaa8\ub378\ub9c1, \uc815\ube44\uacc4\ud68d</li> <li>\uc18c\uc720\uad8c\uacfc \uc870\ud569, \uc0ac\uc5c5\uc131, \uc6a9\uc801\ub960</li> <li>\uae30\ubc18\uc2dc\uc124\uacfc \uacf5\uacf5\uae30\uc5ec</li> <li>1\uae30 \uc2e0\ub3c4\uc2dc \ud2b9\ubcc4\ubc95\uacfc \ub178\ud6c4\uacc4\ud68d\ub3c4\uc2dc \uc815\ube44</li> <li>\uae30\uc874 PDF: UH_06 s.2\u00b76(\ud589\uc815\uacc4\ud68d\u00b7\uc774\uc775\ud615\ub7c9\u00b7\uc815\ube44\uc0ac\uc5c5 \ubc95\uccb4\uacc4: \ub3c4\uc815\ubc95\u00b7\ub3c4\uc2dc\uc7ac\uc0dd\ubc95\u00b7\ube48\uc9d1\ud2b9\ub840\ubc95), UH_03(\uc2e0) s.49\u00b757(\uc6b0\uadf9\uc2e0\uc544\ud30c\ud2b8 \ub9ac\ubaa8\ub378\ub9c1\u00b7\uc81c\ub3c4\uc801 \ub3c4\uc2dc\ud615\ud0dc \uc0dd\uc0b0 \uc885\ud569)</li> <li>\u203b \ubcf4\uac15 \ud544\uc694: \uc548\uc804\uc9c4\ub2e8\u00b7\uc7ac\uac74\ucd95 \uc808\ucc28\u00b7\ub9ac\ubaa8\ub378\ub9c1\u00b71\uae30 \uc2e0\ub3c4\uc2dc \ud2b9\ubcc4\ubc95\u00b7\ub178\ud6c4\uacc4\ud68d\ub3c4\uc2dc \uc815\ube44 \ud2b9\ubcc4\ubc95(UH_02 s.12\uc5d0 \uc5b8\uae09\ub9cc) \u2014 \ub300\ubd80\ubd84 \uc2e0\uaddc</li> </ul>"},{"location":"urbanism-housing/schedule/#12","title":"12 \uc8fc\ucc28: \ud2b9\uac15","text":"<p>2026-11-18</p> <p>\uc544\ud30c\ud2b8 \uae40\uc740\uc815 \uad50\uc218\ub2d8</p>"},{"location":"urbanism-housing/schedule/#13","title":"13 \uc8fc\ucc28: \ud604\uc7ac \uc774\uc288 \uc815\ub9ac","text":"<p>2026-11-25 \uc6b0\ub9ac\uc758 \ub3c4\uc2dc\uc8fc\uac70\ud615\ud0dc</p> <ul> <li>\ucd95\uc18c\ub3c4\uc2dc\uc640 \ube48\uc9d1</li> <li>\uc218\ub3c4\uad8c \uc9d1\uc911\uacfc \uc9c0\ubc29 \uc1e0\ud1f4</li> <li>\uc8fc\uac70\ud615\ud0dc \ud68d\uc77c\ud654\uc640 \uc544\ud30c\ud2b8 \uc911\uc2ec\uc131</li> <li>\ube44\uc544\ud30c\ud2b8 \ucde8\uc57d\uc131\uacfc \uc8fc\uac70 \ub2e4\uc591\uc131</li> <li>\uc5b4\ub5bb\uac8c \uc815\ube44\ud560 \uac83\uc778\uac00</li> <li>\uae30\uc874 PDF: UH_02 s.14-16(\uace0\ub839\ud654\u00b71-2\uc778 \uac00\uad6c\u00b7\uc555\ucd95\ub3c4\uc2dc\u00b7\ub3c4\uc2dc\uc7ac\uc0dd), UH_04 s.21-29(\ud615\ud0dc-\ud589\ud0dc\u00b7\uc5d0\ub108\uc9c0/\ubc00\ub3c4\u00b7\ub3c4\uc2ec\ubd80 \uc18c\ub2e8\uc704 \uc815\ube44)</li> <li>\u203b \ubcf4\uac15 \ud544\uc694: \ucd95\uc18c\ub3c4\uc2dc\u00b7\ube48\uc9d1\u00b7\uc218\ub3c4\uad8c \uc9d1\uc911\uacfc \uc9c0\ubc29 \uc1e0\ud1f4 \u2014 PDF\uc5d0 \uc5c6\uc74c(\uc2e0\uaddc)</li> </ul>"},{"location":"urbanism-housing/schedule/#14","title":"14 \uc8fc\ucc28: \uadf8\ub807\ub2e4\uba74, \ubbf8\ub798\ub294?","text":"<p>2026-12-02 \uae30\uc220\ubcc0\ud654\uc640 \uc0ac\ud68c\ubcc0\ud654 \uc18d \ub3c4\uc2dc\uc8fc\uac70</p> <ul> <li>\uc2a4\ub9c8\ud2b8\uc2dc\ud2f0\uc640 \ub370\uc774\ud130 \uae30\ubc18 \ub3c4\uc2dc\uad00\ub9ac</li> <li>\uae30\ud6c4\uc704\uae30, \uc5d0\ub108\uc9c0, \ubc00\ub3c4, \ubcf4\ud589</li> <li>\uace0\ub839\ud654\uc640 1-2\uc778 \uac00\uad6c</li> <li>\uacf5\uc720\uc8fc\uac70, \ucf54\ub9ac\ube59, \uacf5\uacf5\uc8fc\ud0dd, \uc0ac\ud68c\uc8fc\ud0dd</li> <li>\uc8fc\uac70 \uc548\uc815\uc131\uacfc \ub3c4\uc2dc \ub2e4\uc591\uc131</li> <li>\uae30\uc874 PDF: UH_02 s.14-16(\uae30\ud6c4\ubcc0\ud654\u00b7microclimate\u00b7\uace0\ub839\ud654\u00b7\uc548\uc804\u00b7\uc555\ucd95\ub3c4\uc2dc\u00b7\ub2e4\ud575\ub3c4\uc2dc\u00b7\ub3c4\uc2dc\uc7ac\uc0dd)</li> <li>\u203b \ubcf4\uac15 \ud544\uc694: \uc2a4\ub9c8\ud2b8\uc2dc\ud2f0\u00b7\ub370\uc774\ud130 \uae30\ubc18 \ub3c4\uc2dc\uad00\ub9ac\u00b7\uacf5\uc720\uc8fc\uac70/\ucf54\ub9ac\ube59\u00b7\uc0ac\ud68c\uc8fc\ud0dd \u2014 PDF\uc5d0 \uc5c6\uc74c(\uc2e0\uaddc)</li> </ul>"},{"location":"urbanism-housing/schedule/#15","title":"15 \uc8fc\ucc28: \uae30\ub9d0\uace0\uc0ac","text":"<p>2026-12-09</p>"}]}